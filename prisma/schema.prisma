// Kromuz V2 — Schema Prisma
// Foco do Sprint 1: Motor de Regras + Ingestão de Roteiros Operacionais
//
// Convenções:
//  - Multi-tenant via empresa_id em TODA entidade de negócio (RLS aplicada no Postgres).
//  - Índices compostos sempre começando por empresa_id.
//  - JSONB usado para schemas variáveis (faixas etárias, espécies, etc).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, citext, vector]
  schemas    = ["public"]
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────────────────────────────────────

model Empresa {
  id              String    @id @default(uuid()) @db.Uuid
  nomeEmpresa     String    @map("nome_empresa")
  nomeFantasia    String?   @map("nome_fantasia")
  cpfCnpj         String?   @map("cpf_cnpj")
  status          String    @default("teste")
  planoSlug       String    @default("beta") @map("plano_slug")
  diasTrial       Int       @default(14) @map("dias_trial")
  dataTrialFim    DateTime? @map("data_trial_fim") @db.Date
  nivelPlataforma String    @default("inicio") @map("nivel_plataforma")
  logoUrl         String?   @map("logo_url")
  corPrimaria     String?   @map("cor_primaria")
  telefone        String?
  email           String?
  inscricaoEstadual String? @map("inscricao_estadual")
  inscricaoMunicipal String? @map("inscricao_municipal")
  cep             String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  uf              String?
  asaasCustomerId String?   @map("asaas_customer_id")
  statusAssinatura String   @default("ACTIVE") @map("status_assinatura")
  planoSaasId     String?   @map("plano_saas_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  bancos               Banco[]
  convenios            Convenio[]
  produtosCredito      ProdutoCredito[]
  tabelasCoeficiente   TabelaCoeficiente[]
  regrasProduto        RegraProdutoCredito[]
  roteirosOperacionais RoteiroOperacional[]
  importacoesPdf       ImportacaoPDF[]
  usuarios             UsuarioPerfil[]
  bancoConvenios       BancoConvenio[]
  auditLogs            AuditLog[]
  propostas            Proposta[]
  leads                Lead[]
  pipelineColunas      PipelineColuna[]
  metas                Meta[]
  simulacoes           SimulacaoCredito[]
  faturasBanco         FaturaBanco[]
  conhecimentoBevi     ConhecimentoBevi[]

  canais               CanalComunicacao[]
  conversas            Conversa[]
  campanhas            CampanhaDisparo[]
  filaRpa              FilaRpa[]
  campanhasMarketing   CampanhaMarketing[]
  logsAtividades       LogAtividade[]
  regrasComissao       RegraComissao[]
  cargos               Cargo[]
  
  planoSaaS            PlanoSaaS? @relation(fields: [planoSaasId], references: [id])
  faturasSaaS          FaturaSaaS[]

  @@index([status])
  @@map("empresa")
  @@schema("public")
}

model UsuarioPerfil {
  id         String   @id @default(uuid()) @db.Uuid
  empresaId  String   @map("empresa_id") @db.Uuid
  authUserId String   @unique @map("auth_user_id") @db.Uuid
  email               String
  nome                String?
  perfilSlug          String   @default("vendedor") @map("perfil_slug")
  isSuperAdmin        Boolean  @default(false) @map("is_super_admin")
  cargoId             String?  @map("cargo_id") @db.Uuid
  avatarUrl           String?  @map("avatar_url")

  // Dados Pessoais
  telefone            String?
  cpf                 String?
  dataNascimento      DateTime? @map("data_nascimento") @db.Date
  rg                  String?
  orgaoEmissor        String?  @map("orgao_emissor")
  genero              String?  // M, F, Outro
  estadoCivil         String?  @map("estado_civil")
  timeFavorito        String?  @map("time_favorito")
  fotoUrl             String?  @map("foto_url")

  // Endereço
  cep                 String?
  logradouro          String?
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String?
  uf                  String?

  // Dados Bancários
  bancoNome           String?  @map("banco_nome")
  bancoAgencia        String?  @map("banco_agencia")
  bancoConta          String?  @map("banco_conta")
  bancoTipoConta      String?  @map("banco_tipo_conta") // corrente, poupanca
  chavePix            String?  @map("chave_pix")
  tipoChavePix        String?  @map("tipo_chave_pix") // cpf, email, telefone, aleatoria

  // Contratação
  dataContratacao     DateTime? @map("data_contratacao") @db.Date
  dataDesligamento    DateTime? @map("data_desligamento") @db.Date
  observacoesPessoais String?   @map("observacoes_pessoais") @db.Text
  documentosUrls      Json?     @map("documentos_urls") @db.JsonB // [{nome, url, tipo}]
  
  // Regras de Remuneração
  tipoRemuneracao     String   @default("SEM_COMISSAO") @map("tipo_remuneracao") // SEM_COMISSAO, PERCENTUAL_FIXO, FAIXAS_META
  baseCalculoComissao String   @default("VOLUME") @map("base_calculo_comissao") // VOLUME, LUCRO_LOJA
  salarioFixo         Float?   @map("salario_fixo")
  percentualFixo      Float?   @map("percentual_fixo")
  regrasFaixas        Json?    @map("regras_faixas") // Array de objetos { minVolume, percentual }

  // Rede de Parceiros (Master / Sub)
  masterId            String?  @map("master_id") @db.Uuid
  percentualSplitMaster Float? @map("percentual_split_master") // ex: 20% fica pro Master

  // Controle de Horário de Acesso
  horarioInicio       String?  @map("horario_inicio")   // "08:00"
  horarioFim          String?  @map("horario_fim")      // "18:00"
  diasAcesso          Json?    @map("dias_acesso")      // ["seg","ter","qua","qui","sex"]

  ativo               Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cargo   Cargo?  @relation(fields: [cargoId], references: [id], onDelete: SetNull)
  conversas Conversa[]
  logsAtividades LogAtividade[]
  
  master              UsuarioPerfil? @relation("RedeParceiros", fields: [masterId], references: [id], onDelete: SetNull)
  subCorretores       UsuarioPerfil[] @relation("RedeParceiros")

  @@index([empresaId])
  @@index([authUserId])
  @@map("usuario_perfil")
  @@schema("public")
}

model Cargo {
  id          String   @id @default(uuid()) @db.Uuid
  empresaId   String   @map("empresa_id") @db.Uuid
  nome        String
  slug        String
  descricao   String?
  permissoes  Json     @default("{}") @db.JsonB
  isDefault   Boolean  @default(false) @map("is_default")
  isSistema   Boolean  @default(false) @map("is_sistema")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  empresa     Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarios    UsuarioPerfil[]

  @@unique([empresaId, slug])
  @@index([empresaId])
  @@map("cargo")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// MOTOR DE REGRAS — NÚCLEO (Sprint 1)
// ─────────────────────────────────────────────────────────────────────────────

model Banco {
  id                      String   @id @default(uuid()) @db.Uuid
  empresaId               String   @map("empresa_id") @db.Uuid
  nome                    String
  codigoCompe             String?  @map("codigo_compe")
  cnpj                    String?
  tipo                    String   @default("consignado")
  tipoBanco               String   @default("consignado") @map("tipo_banco")
  status                  String   @default("ativo")
  ativo                   Boolean  @default(true)
  ativoSimulacao          Boolean  @default(false) @map("ativo_simulacao")
  ordem                   Int      @default(99)
  fatorSaldo              Float?   @map("fator_saldo")
  multiplicadorMaxParcela Float?   @map("multiplicador_max_parcela")
  prazoMaximo             Int?     @map("prazo_maximo")
  parcelasMinimasSrcc     Int      @default(0) @map("parcelas_minimas_srcc")
  observacoes             String?
  logoUrl                 String?  @map("logo_url")
  permiteIntegracao       Boolean  @default(false) @map("permite_integracao")
  credenciaisApi          Json?    @map("credenciais_api")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  empresa              Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtosCredito      ProdutoCredito[]
  tabelasCoeficiente   TabelaCoeficiente[]
  regrasProduto        RegraProdutoCredito[]
  roteirosOperacionais RoteiroOperacional[]
  bancoConvenios       BancoConvenio[]

  @@unique([empresaId, nome])
  @@index([empresaId, ativo])
  @@map("banco")
  @@schema("public")
}

model Convenio {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  nome      String
  slug      String
  tipo      String?
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  empresa            Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  produtosCredito    ProdutoCredito[]
  tabelasCoeficiente TabelaCoeficiente[]
  regrasProduto      RegraProdutoCredito[]
  bancoConvenios     BancoConvenio[]

  @@unique([empresaId, slug])
  @@index([empresaId, ativo])
  @@map("convenio")
  @@schema("public")
}

model BancoConvenio {
  id          String   @id @default(uuid()) @db.Uuid
  empresaId   String   @map("empresa_id") @db.Uuid
  bancoId     String   @map("banco_id") @db.Uuid
  convenioId  String   @map("convenio_id") @db.Uuid
  ativo       Boolean  @default(true)
  observacoes String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  empresa  Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  banco    Banco    @relation(fields: [bancoId], references: [id], onDelete: Cascade)
  convenio Convenio @relation(fields: [convenioId], references: [id], onDelete: Cascade)

  @@unique([empresaId, bancoId, convenioId])
  @@index([empresaId])
  @@map("banco_convenio")
  @@schema("public")
}

enum TipoOperacao {
  EMPRESTIMO_CONSIGNADO
  REFINANCIAMENTO
  PORTABILIDADE
  PORTABILIDADE_REFIN
  CARTAO_CONSIGNADO
  CARTAO_BENEFICIO

  @@schema("public")
}

model ProdutoCredito {
  id               String       @id @default(uuid()) @db.Uuid
  empresaId        String       @map("empresa_id") @db.Uuid
  bancoId          String       @map("banco_id") @db.Uuid
  convenioId       String?      @map("convenio_id") @db.Uuid
  nomeProduto      String       @map("nome_produto")
  tipoProduto      TipoOperacao @map("tipo_produto")
  prazoMaximo      Int?         @map("prazo_maximo")
  taxaMedia        Float?       @map("taxa_media")
  permiteSeguro    Boolean      @default(false) @map("permite_seguro")
  percentualSaque  Float?       @map("percentual_saque")
  percentualCompra Float?       @map("percentual_compra")
  ativo            Boolean      @default(true)
  observacoes      String?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  empresa  Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  banco    Banco     @relation(fields: [bancoId], references: [id], onDelete: Cascade)
  convenio Convenio? @relation(fields: [convenioId], references: [id], onDelete: SetNull)

  tabelasCoeficiente TabelaCoeficiente[]
  regras             RegraProdutoCredito[]

  @@unique([empresaId, bancoId, tipoProduto, convenioId])
  @@index([empresaId, bancoId])
  @@map("produto_credito")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// TABELAS DE COEFICIENTES (COMERCIAL)
// ─────────────────────────────────────────────────────────────────────────────

model TabelaCoeficiente {
  id                 String   @id @default(uuid()) @db.Uuid
  empresaId          String   @map("empresa_id") @db.Uuid
  bancoId            String   @map("banco_id") @db.Uuid
  produtoId          String   @map("produto_id") @db.Uuid
  convenioId         String?  @map("convenio_id") @db.Uuid
  
  nome               String
  prazo              Int
  taxaJurosMensal    Float    @map("taxa_juros_mensal")
  coeficiente        Float
  
  comissaoFlatPct    Float?   @map("comissao_flat_pct")
  comissaoRepassePct Float?   @map("comissao_repasse_pct")
  
  ativo              Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  empresa  Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  banco    Banco          @relation(fields: [bancoId], references: [id], onDelete: Cascade)
  produto  ProdutoCredito @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  convenio Convenio?      @relation(fields: [convenioId], references: [id], onDelete: SetNull)

  @@index([empresaId, bancoId, produtoId])
  @@map("tabela_coeficiente")
  @@schema("public")
}

// ⭐ Regra Operacional do Produto — extraída via IA dos PDFs dos bancos.
model RegraProdutoCredito {
  id           String       @id @default(uuid()) @db.Uuid
  empresaId    String       @map("empresa_id") @db.Uuid
  bancoId      String       @map("banco_id") @db.Uuid
  bancoNome    String       @map("banco_nome")
  produtoId    String       @map("produto_id") @db.Uuid
  produtoNome  String       @map("produto_nome")
  convenioId   String?      @map("convenio_id") @db.Uuid
  convenioNome String?      @map("convenio_nome")
  tipoOperacao TipoOperacao @map("tipo_operacao")
  ativa        Boolean      @default(true)
  prioridade   Int          @default(0)

  faixasEtarias Json @default("[]") @map("faixas_etarias") @db.JsonB
  especies      Json @default("{}") @db.JsonB

  // Regras Pessoais
  representanteLegalPermitido Boolean? @map("representante_legal_permitido")
  idadeMaxRepresentante       Int?     @map("idade_max_representante")
  analfabetoPermitido         Boolean? @map("analfabeto_permitido")

  // Regras de Convênio / UF
  ufBloqueadas   String[] @default([]) @map("uf_bloqueadas")
  ddbMinimoDias  Int?     @map("ddb_minimo_dias") // IN100

  margemPadraoPct Float? @map("margem_padrao_pct")
  margemLoasPct   Float? @map("margem_loas_pct")

  margemNovaPermitido Boolean @default(true) @map("margem_nova_permitido")
  margemNovaValorMin  Float?  @map("margem_nova_valor_min")
  margemNovaValorMax  Float?  @map("margem_nova_valor_max")

  refinPermitido        Boolean  @default(true) @map("refin_permitido")
  refinParcelasMinPagas Int?     @map("refin_parcelas_min_pagas")
  refinAgregaMargem     Boolean? @map("refin_agrega_margem")
  refinPermiteMargemNeg Boolean? @map("refin_permite_margem_negativa")
  refinValorMin         Float?   @map("refin_valor_min")
  refinTrocoMin         Float?   @map("refin_troco_min")

  portPermitido          Boolean  @default(true) @map("port_permitido")
  portParcelasMinPagas   Int?     @map("port_parcelas_min_pagas")
  portValorMin           Float?   @map("port_valor_min")
  portPermiteReduzirParc Boolean? @map("port_permite_reduzir_parcela")
  portPermiteMargemNeg   Boolean? @map("port_permite_margem_negativa")
  portMaxContratosUnica  Int?     @map("port_max_contratos_unica_digitacao")

  taxaMinimaAm Float? @map("taxa_minima_am")
  taxaMaximaAm Float? @map("taxa_maxima_am")

  maxContratosPorBeneficio Int?    @map("max_contratos_por_beneficio")
  dataCorte                String? @map("data_corte")

  limiteCartaoMinimo Float? @map("limite_cartao_minimo")
  limiteCartaoMaximo Float? @map("limite_cartao_maximo")
  fatorRmc           Float? @map("fator_rmc")
  parcelaMinima      Float? @map("parcela_minima")

  saldoDevedorMaximo  Float? @map("saldo_devedor_maximo")
  trocoMinimoLiberado Float? @map("troco_minimo_liberado")

  versaoRoteiro          String? @map("versao_roteiro")
  dataAtualizacaoRoteiro String? @map("data_atualizacao_roteiro")
  validadeRoteiro        String? @map("validade_roteiro")

  bancosPagamento Json @default("[]") @map("bancos_pagamento") @db.JsonB

  documentosObrigatorios String[] @default([]) @map("documentos_obrigatorios")
  publicoExcluido        String[] @default([]) @map("publico_excluido")

  restricoesPorEspecie Json @default("[]") @map("restricoes_por_especie") @db.JsonB

  observacoes String?

  fonteTipo        String?   @map("fonte_tipo")
  fonteArquivoUrl  String?   @map("fonte_arquivo_url")
  fonteArquivoNome String?   @map("fonte_arquivo_nome")
  fonteModeloIa    String?   @map("fonte_modelo_ia")
  fonteExtraidoEm  DateTime? @map("fonte_extraido_em")

  importacaoPdfId String? @map("importacao_pdf_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  empresa       Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  banco         Banco          @relation(fields: [bancoId], references: [id], onDelete: Cascade)
  produto       ProdutoCredito @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  convenio      Convenio?      @relation(fields: [convenioId], references: [id], onDelete: SetNull)
  importacaoPdf ImportacaoPDF? @relation(fields: [importacaoPdfId], references: [id], onDelete: SetNull)

  @@unique([empresaId, bancoId, produtoId, tipoOperacao])
  @@index([empresaId, bancoId, ativa])
  @@index([empresaId, tipoOperacao])
  @@map("regra_produto_credito")
  @@schema("public")
}

model RoteiroOperacional {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  bancoId         String   @map("banco_id") @db.Uuid
  bancoNome       String   @map("banco_nome")
  produto         String
  titulo          String
  descricao       String?
  versaoAtual     String   @default("1.0") @map("versao_atual")
  status          String   @default("rascunho")
  arquivoPdfUrl   String?  @map("arquivo_pdf_url")
  regrasExtraidas Int      @default(0) @map("regras_extraidas")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  banco   Banco   @relation(fields: [bancoId], references: [id], onDelete: Cascade)

  @@index([empresaId, bancoId])
  @@map("roteiro_operacional")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// FINANCEIRO / FATURAMENTO (Sprint 17)
// ─────────────────────────────────────────────────────────────────────────────

model FaturaBanco {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  bancoNome       String   @map("banco_nome")
  
  codigoLote      String   @unique @map("codigo_lote") // Ex: LOTE-PAN-001
  status          String   @default("PENDENTE") // PENDENTE, PAGA, CANCELADA
  
  dataEmissao     DateTime @default(now()) @map("data_emissao")
  dataVencimento  DateTime? @map("data_vencimento")
  dataPagamento   DateTime? @map("data_pagamento")
  
  valorTotal      Float    @map("valor_total")
  observacoes     String?
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  propostas       Proposta[]
  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, bancoNome, status])
  @@map("fatura_banco")
  @@schema("public")
}

model ImportacaoPDF {
  id           String    @id @default(uuid()) @db.Uuid
  empresaId    String    @map("empresa_id") @db.Uuid
  arquivoUrl   String    @map("arquivo_url")
  nomeArquivo  String    @map("nome_arquivo")
  bancoHint    String?   @map("banco_hint")
  status       String    @default("pendente")
  progresso    Int       @default(0)
  etapa        String?
  logs         String?
  erro         String?
  modeloIa     String?   @map("modelo_ia")
  resultado    Json?     @db.JsonB
  usuarioEmail String?   @map("usuario_email")
  iniciadoEm   DateTime? @map("iniciado_em")
  concluidoEm  DateTime? @map("concluido_em")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  empresa       Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  regrasGeradas RegraProdutoCredito[]

  @@index([empresaId, status])
  @@index([empresaId, createdAt(sort: Desc)])
  @@map("importacao_pdf")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOG DE AUDITORIA (Sprint 11)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  empresaId    String   @map("empresa_id") @db.Uuid
  usuarioEmail String   @map("usuario_email")
  usuarioNome  String?  @map("usuario_nome")
  acao         String   // criou, editou, deletou, importou, vinculou, desvinculou
  entidade     String   // regra, banco, produto, convenio, tabela, empresa, usuario
  entidadeId   String?  @map("entidade_id") @db.Uuid
  entidadeNome String?  @map("entidade_nome")
  detalhes     Json?    @db.JsonB  // campos alterados { campo: { de: ..., para: ... } }
  ip           String?
  createdAt    DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, createdAt(sort: Desc)])
  @@index([empresaId, entidade])
  @@map("audit_log")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// ESTEIRA DE PROPOSTAS / CRM (Sprint 12)
// ─────────────────────────────────────────────────────────────────────────────

enum StatusProposta {
  RASCUNHO
  SIMULADA
  DIGITADA
  PENDENTE
  APROVADA
  REPROVADA
  PAGA
  CANCELADA

  @@schema("public")
}

model Proposta {
  id              String         @id @default(uuid()) @db.Uuid
  empresaId       String         @map("empresa_id") @db.Uuid
  bancoId         String?        @map("banco_id") @db.Uuid
  produtoId       String?        @map("produto_id") @db.Uuid
  convenioId      String?        @map("convenio_id") @db.Uuid
  leadId          String?        @map("lead_id") @db.Uuid

  // Cliente
  clienteNome     String         @map("cliente_nome")
  clienteCpf      String?        @map("cliente_cpf")
  clienteTelefone String?        @map("cliente_telefone")
  numeroBeneficio String?        @map("numero_beneficio")
  especieBeneficio Int?          @map("especie_beneficio")

  // Operação
  tipoOperacao    String?        @map("tipo_operacao")
  status          StatusProposta @default(RASCUNHO)
  integradaBanco  Boolean        @default(false) @map("integrada_banco")
  codigoPropostaBanco String?    @map("codigo_proposta_banco")
  valorParcela    Float?         @map("valor_parcela")
  valorLiberado   Float?         @map("valor_liberado")
  prazo           Int?
  taxaJuros       Float?         @map("taxa_juros")
  valorComissao   Float?         @map("valor_comissao")

  // Meta
  bancoNome       String?        @map("banco_nome")
  produtoNome     String?        @map("produto_nome")
  convenioNome    String?        @map("convenio_nome")
  vendedorEmail   String?        @map("vendedor_email")
  vendedorNome    String?        @map("vendedor_nome")

  // Rastreio de Gargalos
  historicoStatus Json?    @map("historico_status") @db.JsonB @default("[]")

  // Portabilidade — Controle Operacional
  bancoOrigem          String?   @map("banco_origem")
  saldoDevedor         Float?    @map("saldo_devedor")
  dataSolicitacaoSaldo DateTime? @map("data_solicitacao_saldo")
  dataRetornoSaldo     DateTime? @map("data_retorno_saldo")
  saldoRetornado       Boolean   @default(false) @map("saldo_retornado")
  dataProximoRetorno   DateTime? @map("data_proximo_retorno")

  observacoes     String?
  promotora       String?
  tabela          String?
  
  // Datas do funil
  digitadaEm      DateTime?      @map("digitada_em")
  aprovadaEm      DateTime?      @map("aprovada_em")
  pagaEm          DateTime?      @map("paga_em")
  canceladaEm     DateTime?      @map("cancelada_em")

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Links Financeiros
  faturaBancoId   String?        @map("fatura_banco_id") @db.Uuid
  faturaBanco     FaturaBanco?   @relation(fields: [faturaBancoId], references: [id])

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, status])
  @@index([empresaId, createdAt(sort: Desc)])
  @@index([empresaId, vendedorEmail])
  @@map("proposta")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEADS / CRM (Sprint 13)
// ─────────────────────────────────────────────────────────────────────────────

// Status foram migrados para pipeline_coluna dinâmico

model Lead {
  id              String     @id @default(uuid()) @db.Uuid
  empresaId       String     @map("empresa_id") @db.Uuid

  // Dados pessoais
  nome            String
  cpf             String?
  telefone        String?
  email           String?
  dataNascimento  DateTime?  @map("data_nascimento") @db.Date
  uf              String?
  cidade          String?

  // Benefício INSS
  numeroBeneficio String?    @map("numero_beneficio")
  especieBeneficio Int?      @map("especie_beneficio")
  margemLivre     Float?     @map("margem_livre")
  margemRmc       Float?     @map("margem_rmc")
  margemRcc       Float?     @map("margem_rcc")

  // Pipeline
  status          String     @default("NOVO")
  origem          String?    // indicacao, site, whatsapp, importacao, manual
  canalContato    String?    @map("canal_contato") // whatsapp, telefone, presencial
  vendedorEmail   String?    @map("vendedor_email")
  vendedorNome    String?    @map("vendedor_nome")

  // Marketing e UTMs
  utmSource       String?    @map("utm_source")
  utmMedium       String?    @map("utm_medium")
  utmCampaign     String?    @map("utm_campaign")
  campanhaId      String?    @map("campanha_id") @db.Uuid
  campanha        CampanhaMarketing? @relation(fields: [campanhaId], references: [id], onDelete: SetNull)

  // Operação potencial
  tipoOperacao    String?       @map("tipo_operacao")
  valorLiberado   Float?        @map("valor_liberado")
  bancoPreferido  String?       @map("banco_preferido")
  convenioNome    String?       @map("convenio_nome")

  // Financeiro
  renda           Float?
  ddb             DateTime?     @db.Date  // Data de Despacho do Benefício

  // Endereço
  cep             String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?

  // Dados bancários do cliente
  bancoCliente    String?       @map("banco_cliente")
  agenciaCliente  String?       @map("agencia_cliente")
  contaCliente    String?       @map("conta_cliente")
  tipoContaCliente String?     @map("tipo_conta_cliente")  // CC, CP

  // Importação / Operação
  dataDigitacao       DateTime?   @map("data_digitacao")
  codigoPropostaBanco String?     @map("codigo_proposta_banco") // ADE
  promotora           String?
  parcelaAtual        Float?      @map("parcela_atual")
  saldoDevedor        Float?      @map("saldo_devedor")
  retornoSaldo        String?     @map("retorno_saldo")
  tabela              String?

  observacoes     String?
  ultimoContato   DateTime?  @map("ultimo_contato")
  proximoContato  DateTime?  @map("proximo_contato")
  motivoPerda     String?    @map("motivo_perda")
  score           Int        @default(0)

  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  arquivos LeadArquivo[]
  conversas Conversa[]

  @@index([empresaId, status])
  @@index([empresaId, vendedorEmail])
  @@index([empresaId, createdAt(sort: Desc)])
  @@map("lead")
  @@schema("public")
}

model LeadArquivo {
  id        String   @id @default(uuid()) @db.Uuid
  leadId    String   @map("lead_id") @db.Uuid
  nome      String
  url       String
  tipo      String?  // Ex: application/pdf, image/jpeg
  tamanho   Int?     // bytes
  createdAt DateTime @default(now()) @map("created_at")

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_arquivo")
  @@schema("public")
}

model PipelineColuna {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  nome      String
  cor       String?
  ordem     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([empresaId, ordem])
  @@map("pipeline_coluna")
  @@schema("public")
}


// ─────────────────────────────────────────────────────────────────────────────
// METAS (Sprint 16)
// ─────────────────────────────────────────────────────────────────────────────

model Meta {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid

  vendedorEmail   String   @map("vendedor_email")
  vendedorNome    String?  @map("vendedor_nome")
  mes             Int      // 1-12
  ano             Int

  // Metas
  metaPropostas   Int?     @map("meta_propostas")    // qtd propostas pagas
  metaVolume      Float?   @map("meta_volume")       // R$ liberado
  metaLeads       Int?     @map("meta_leads")        // qtd leads convertidos
  metaComissao    Float?   @map("meta_comissao")     // R$ comissão

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, vendedorEmail, mes, ano])
  @@index([empresaId, ano, mes])
  @@map("meta")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// INTELIGÊNCIA & SIMULADORES (Sprint 13)
// ─────────────────────────────────────────────────────────────────────────────

model SimulacaoCredito {
  id                   String   @id @default(uuid()) @db.Uuid
  empresaId            String   @map("empresa_id") @db.Uuid
  clienteNome          String?  @map("cliente_nome")
  beneficioTipo        String   @map("beneficio_tipo")
  especieBeneficio     String?  @map("especie_beneficio")
  idade                Int
  valorBeneficio       Float?   @map("valor_beneficio")
  margemDisponivel     Float?   @map("margem_disponivel")
  valorSolicitado      Float?   @map("valor_solicitado")
  prazoDesejado        Int?     @map("prazo_desejado")
  melhorBanco          String?  @map("melhor_banco")
  melhorScore          Int?     @map("melhor_score")
  totalBancosElegiveis Int      @default(0) @map("total_bancos_elegiveis")
  createdAt            DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, createdAt(sort: Desc)])
  @@map("simulacao_credito")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// BASE DE CONHECIMENTO & RAG (Sprint 19)
// ─────────────────────────────────────────────────────────────────────────────

model ConhecimentoBevi {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid // Permite isolar conhecimento por tenant se necessário
  
  categoria       String   // INSS, FGTS, SIAPE, etc.
  pasta           String   // Nome do banco ou órgão (Icred, Pan, Acre, etc.)
  tituloArtigo    String   @map("titulo_artigo")
  urlOrigem       String   @map("url_origem")
  
  conteudoChunk   String   @map("conteudo_chunk") @db.Text // Pedaço do Markdown
  
  // Usamos Unsupported("vector") no Prisma client para pgvector
  embedding       Unsupported("vector(768)")? // Tamanho do vetor Gemini flash/Google
  
  createdAt       DateTime @default(now()) @map("created_at")

  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, categoria])
  @@map("conhecimento_bevi")
  @@schema("public")
}


// ─────────────────────────────────────────────────────────────────────────────
// OMNICHANNEL & AUTOMAÇÃO DE IA (Sprint 18)
// ─────────────────────────────────────────────────────────────────────────────

model CanalComunicacao {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  tipo            String   // WHATSAPP, INSTAGRAM, FACEBOOK
  nomeCanal       String   @map("nome_canal") // Ex: "WhatsApp Principal"
  identificador   String?  // Número ou @ do insta
  credenciaisApi  Json     @default("{}") @map("credenciais_api") @db.JsonB
  ativo           Boolean  @default(true)
  
  // Configurações de IA
  botAtivo        Boolean  @default(false) @map("bot_ativo")
  promptBase      String?  @map("prompt_base") @db.Text
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  conversas       Conversa[]
  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, tipo])
  @@map("canal_comunicacao")
  @@schema("public")
}

model Conversa {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  canalId         String   @map("canal_id") @db.Uuid
  leadId          String?  @map("lead_id") @db.Uuid
  
  clienteNome     String   @map("cliente_nome")
  clienteContato  String   @map("cliente_contato") // número de telefone ou ID social
  
  status          String   @default("AGUARDANDO_IA") // AGUARDANDO_IA, ABERTO, FECHADO
  vendedorId      String?  @map("vendedor_id") @db.Uuid
  
  ultimaMensagem  String?  @map("ultima_mensagem")
  lida            Boolean  @default(false)
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  mensagens       Mensagem[]
  canal           CanalComunicacao @relation(fields: [canalId], references: [id], onDelete: Cascade)
  lead            Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  vendedor        UsuarioPerfil?   @relation(fields: [vendedorId], references: [id], onDelete: SetNull)
  empresa         Empresa          @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, status])
  @@index([empresaId, canalId])
  @@map("conversa")
  @@schema("public")
}

model Mensagem {
  id              String   @id @default(uuid()) @db.Uuid
  conversaId      String   @map("conversa_id") @db.Uuid
  
  remetente       String   // LEAD, VENDEDOR, IA, SISTEMA
  tipo            String   @default("WHATSAPP") // WHATSAPP, INTERNA
  conteudo        String   @db.Text
  tipoConteudo    String   @default("TEXTO") @map("tipo_conteudo") // TEXTO, IMAGEM, AUDIO, ARQUIVO
  urlMidia        String?  @map("url_midia")
  
  lida            Boolean  @default(false)
  agendadoPara    DateTime? @map("agendado_para")
  
  createdAt       DateTime @default(now()) @map("created_at")

  conversa        Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@index([conversaId, createdAt])
  @@index([agendadoPara])
  @@map("mensagem")
  @@schema("public")
}

model CampanhaDisparo {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  canalId         String   @map("canal_id") @db.Uuid
  
  nome            String
  mensagemTemplate String  @map("mensagem_template") @db.Text
  status          String   @default("AGENDADA") // AGENDADA, EXECUTANDO, CONCLUIDA, CANCELADA
  
  dataAgendamento DateTime? @map("data_agendamento")
  filtrosDeBase   Json     @default("{}") @map("filtros_de_base") @db.JsonB
  
  leadsAtingidos  Int      @default(0) @map("leads_atingidos")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, status])
  @@map("campanha_disparo")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// SAAS BILLING E SUPER-ADMIN
// ─────────────────────────────────────────────────────────────────────────────

model PlanoSaaS {
  id              String   @id @default(uuid()) @db.Uuid
  nome            String
  precoMensal     Float    @map("preco_mensal")
  limiteUsuarios  Int      @default(5) @map("limite_usuarios")
  limiteLeads     Int      @default(1000) @map("limite_leads")
  limiteDisparos  Int      @default(0) @map("limite_disparos")
  
  empresas        Empresa[]

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("plano_saas")
  @@schema("public")
}

model FaturaSaaS {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  asaasInvoiceId  String?  @map("asaas_invoice_id")
  valor           Float
  status          String   @default("PENDING") // PENDING, PAID, OVERDUE
  vencimento      DateTime @db.Date
  linkPagamento   String?  @map("link_pagamento")
  
  empresa         Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([empresaId])
  @@index([status])
  @@map("fatura_saas")
  @@schema("public")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEGA EXPANSÃO (FASE 4) - RPA E MARKETING
// ─────────────────────────────────────────────────────────────────────────────

model FilaRpa {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  tipo            String   // EXTRACAO_INSS, DIGITACAO_PROPOSTA
  referenciaId    String   @map("referencia_id") @db.Uuid // Lead ID ou Proposta ID
  payload         Json     @default("{}") @db.JsonB
  status          String   @default("PENDENTE") // PENDENTE, PROCESSANDO, CONCLUIDO, FALHA
  tentativas      Int      @default(0)
  logs            String?  @db.Text
  resultadoUrl    String?  @map("resultado_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, status])
  @@map("fila_rpa")
  @@schema("public")
}

model CampanhaMarketing {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  nome            String
  origem          String   // FACEBOOK, GOOGLE
  custoTotal      Float    @default(0) @map("custo_total")
  leadsGerados    Int      @default(0) @map("leads_gerados")
  dataInicio      DateTime @map("data_inicio")
  dataFim         DateTime? @map("data_fim")
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  leads   Lead[]

  @@index([empresaId, ativo])
  @@map("campanha_marketing")
  @@schema("public")
}

model LogAtividade {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  usuarioId       String   @map("usuario_id") @db.Uuid
  tipo            String   // ALTERACAO_STATUS, VISUALIZACAO_DADOS, LOGIN, CRIACAO
  recurso         String   // LEAD, PROPOSTA, USUARIO
  recursoId       String   @map("recurso_id")
  descricao       String   @db.Text
  ip              String?
  userAgent       String?  @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuario UsuarioPerfil @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([empresaId, recurso, recursoId])
  @@map("log_atividade")
  @@schema("public")
}

model RegraComissao {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  nome            String
  banco           String?
  convenio        String?  @map("convenio")
  tipoOperacao    String?  @map("tipo_operacao")
  percentualSplit Float    @map("percentual_split") // Quanto do total vai para o sub-corretor
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId, banco, ativo])
  @@map("regra_comissao")
  @@schema("public")
}
